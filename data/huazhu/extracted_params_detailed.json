  "noi_calculation_summary": {
    "formula": "NOI = 总收入 - 总费用 - 资本性支出",
    "revenue_formula": "总收入 = 酒店收入 + 商业收入 = 客房收入 + OTA收入 + 餐饮收入 + 其他收入 + 商业租金 + 商业物业费",
    "expense_formula": "总费用 = 运营费用 + 物业费用 + 保险费 + 税费 + 管理费",
    "components": {
      "hotel_room_revenue": "ADR * 房间数 * OCC * 当年天数",
      "future_adr_growth": "首年房价 * (1 + CPI增长率) ^ 年期",
      "gop": "酒店总收入 - 酒店运营费用",
      "management_fee": "GOP * 基准费率(通常3-5%)"
    }
